<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    WHAT IS THIS FILE?
    ══════════════════
    XML Mapper for RetailerProfileRepository.
    Handles retailer personal profile (tb_retailer_info) and phone number operations.
-->

<mapper namespace="com.henheang.hphsar.repository.RetailerProfileRepository">

    <!--
        RESULT MAP — Retailer
        ══════════════════════
        Maps snake_case DB columns → camelCase Java fields.

        <collection> for additionalPhoneNumber:
            column="id"    → passes the retailer_info id to the sub-select
            select="..."   → calls getAdditionalPhoneNumberByRetailerInfoId to get List<String>
    -->
    <resultMap id="RetailerResultMap" type="com.henheang.hphsar.model.retailer.Retailer">
        <id     property="id"                   column="id"/>
        <result property="retailerAccountId"    column="retailerAccountId"/>
        <result property="firstName"            column="firstName"/>
        <result property="lastName"             column="lastName"/>
        <result property="gender"               column="gender"/>
        <result property="address"              column="address"/>
        <result property="primaryPhoneNumber"   column="primaryPhoneNumber"/>
        <result property="profileImage"         column="profileImage"/>
        <result property="createdDate"          column="createdDate"/>
        <result property="updatedDate"          column="updatedDate"/>
        <!--
            @Many equivalent in XML.
            After MyBatis fetches the main row, it calls getAdditionalPhoneNumberByRetailerInfoId
            with the value from column "id" and maps the result List<String> into additionalPhoneNumber.
        -->
        <collection property="additionalPhoneNumber"
                    column="id"
                    select="getAdditionalPhoneNumberByRetailerInfoId"/>
    </resultMap>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CREATE PROFILE — INSERT and return the new retailer_info id
         ═══════════════════════════════════════════════════════════════════════
         #{re.firstName} → accesses firstName from the RetailerRequest object
         "re" comes from @Param("re") on the method parameter
    -->

    <select id="createRetailerProfile" resultType="int">
        INSERT INTO tb_retailer_info
        VALUES (DEFAULT, #{currentUserId}, #{re.firstName}, #{re.lastName}, #{re.gender}, #{re.address},
                #{re.primaryPhoneNumber}, #{re.profileImage}, DEFAULT, DEFAULT)
        RETURNING id
    </select>

    <!-- ─── ADDITIONAL PHONE ────────────────────────────────────────────────── -->

    <insert id="insertAdditinalPhoneNumber">
        INSERT INTO tb_retailer_phone
        VALUES (DEFAULT, #{retailerInfoId}, #{additionalPhoneNumber})
    </insert>

    <select id="getAdditionalPhoneNumberByRetailerInfoId" resultType="String">
        SELECT phone_number FROM tb_retailer_phone WHERE retailer_info_id = #{id}
    </select>

    <delete id="deleteAdditionalPhoneNumber">
        DELETE FROM tb_retailer_phone WHERE retailer_info_id = #{retailerInfoId}
    </delete>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GET PROFILE — returns full Retailer with additional phones
         ═══════════════════════════════════════════════════════════════════════
         All columns are aliased to match Java field names.
         The resultMap above handles the @Many phone number collection.
    -->

    <select id="getRetailerProfile" resultMap="RetailerResultMap">
        SELECT id,
               retailer_account_id AS retailerAccountId,
               first_name          AS firstName,
               last_name           AS lastName,
               gender,
               address,
               primary_phone_number AS primaryPhoneNumber,
               profile_image        AS profileImage,
               created_date         AS createdDate,
               updated_date         AS updatedDate
        FROM tb_retailer_info
        WHERE retailer_account_id = #{currentUserId}
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════════
         UPDATE PROFILE
         ═══════════════════════════════════════════════════════════════════════
         No return value — uses <update> tag.
    -->

    <update id="updateRetailerProfile">
        UPDATE tb_retailer_info
        SET first_name           = #{re.firstName},
            last_name            = #{re.lastName},
            gender               = #{re.gender},
            address              = #{re.address},
            primary_phone_number = #{re.primaryPhoneNumber},
            profile_image        = #{re.profileImage}
        WHERE retailer_account_id = #{currentUserId}
    </update>

    <!-- ─── HELPERS ──────────────────────────────────────────────────────────── -->

    <select id="getRetailerInfoId" resultType="int">
        SELECT id FROM tb_retailer_info WHERE retailer_account_id = #{currentUserId}
    </select>

    <select id="checkIfRetailerProfileIsAlreadyCreated" resultType="boolean">
        SELECT EXISTS(SELECT * FROM tb_retailer_info WHERE retailer_account_id = #{currentUserId})
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════════
         LOOKUP METHODS — called by @One nested selects in OrderDistributorMapper
         ═══════════════════════════════════════════════════════════════════════
         These return a single String value used to populate fields in Order objects.
    -->

    <select id="getRetailerNameById" resultType="String">
        SELECT concat(first_name, ' ', last_name) FROM tb_retailer_info
        WHERE retailer_account_id = #{retailerId}
    </select>

    <select id="getRetailerImageById" resultType="String">
        SELECT profile_image FROM tb_retailer_info
        WHERE retailer_account_id = #{retailerId}
    </select>

    <select id="getRetailerAddressById" resultType="String">
        SELECT address FROM tb_retailer_info
        WHERE retailer_account_id = #{retailerId}
    </select>

    <select id="getRetailerPhoneById" resultType="String">
        SELECT primary_phone_number FROM tb_retailer_info
        WHERE retailer_account_id = #{retailerId}
    </select>

    <select id="getRetailerEmailById" resultType="String">
        SELECT email FROM tb_retailer_account
        WHERE id = #{id}
    </select>

</mapper>