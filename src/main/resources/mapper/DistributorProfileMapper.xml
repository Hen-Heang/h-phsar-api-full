<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    WHAT IS THIS FILE?
    ══════════════════
    XML Mapper for DistributorProfileRepository.
    Handles distributor personal profile (tb_distributor_info) and phone number operations.
-->

<mapper namespace="com.henheang.hphsar.repository.DistributorProfileRepository">

    <!--
        RESULT MAP — Distributor
        ═════════════════════════
        Maps snake_case DB column aliases → camelCase Java fields.
        The SELECT queries already alias all columns, so MyBatis auto-mapping
        would also work, but explicit resultMap is more reliable.
    -->
    <resultMap id="DistributorResultMap" type="com.henheang.hphsar.model.distributor.Distributor">
        <id     property="id"                   column="id"/>
        <result property="distributorAccountId" column="distributorAccountId"/>
        <result property="firstName"            column="firstName"/>
        <result property="lastName"             column="lastName"/>
        <result property="gender"               column="gender"/>
        <result property="profileImage"         column="profileImage"/>
        <result property="createdDate"          column="createdDate"/>
        <result property="updatedDate"          column="updatedDate"/>
    </resultMap>

    <!-- ─── GET ADDITIONAL PHONES ───────────────────────────────────────────── -->

    <select id="getAdditionalPhoneNumberByDistributorInfoId" resultType="String">
        SELECT phone_number AS additionalPhoneNUmber
        FROM tb_distributor_phone
        WHERE distributor_info_id = #{id}
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GET PROFILE — returns Distributor object (without additional phones)
         ═══════════════════════════════════════════════════════════════════════
         Additional phones are fetched separately via getAdditionalPhoneNumberByDistributorInfoId
    -->

    <select id="getUserProfile" resultMap="DistributorResultMap">
        SELECT id                       AS id,
               distributor_account_id  AS distributorAccountId,
               first_name              AS firstName,
               last_name               AS lastName,
               profile_image           AS profileImage,
               created_date            AS createdDate,
               updated_date            AS updatedDate,
               gender
        FROM tb_distributor_info
        WHERE distributor_account_id = #{currentUserId}
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════════
         INSERT PROFILE — INSERT and return the inserted row
         ═══════════════════════════════════════════════════════════════════════
         #{dis.firstName} → accesses firstName from DistributorRequest object
         "dis" comes from @Param("dis") on the method parameter
    -->

    <select id="insertDistributorInfo" resultMap="DistributorResultMap">
        INSERT INTO tb_distributor_info(id, distributor_account_id, first_name, last_name, gender, profile_image, created_date, updated_date)
        VALUES (DEFAULT, #{currentUserId}, #{dis.firstName}, #{dis.lastName}, #{dis.gender}, #{dis.profileImage}, DEFAULT, DEFAULT)
        RETURNING id,
                  distributor_account_id AS distributorAccountId,
                  first_name             AS firstName,
                  last_name              AS lastName,
                  gender,
                  profile_image          AS profileImage,
                  created_date           AS createdDate,
                  updated_date           AS updatedDate
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════════
         UPDATE PROFILE — UPDATE and return the updated row
         ═══════════════════════════════════════════════════════════════════════
    -->

    <select id="updateUserProfile" resultMap="DistributorResultMap">
        UPDATE tb_distributor_info
        SET first_name    = #{dis.firstName},
            last_name     = #{dis.lastName},
            gender        = #{dis.gender},
            profile_image = #{dis.profileImage},
            updated_date  = NOW()
        WHERE distributor_account_id = #{currentUserId}
        RETURNING id,
                  distributor_account_id AS distributorAccountId,
                  first_name             AS firstName,
                  last_name              AS lastName,
                  gender,
                  profile_image          AS profileImage,
                  created_date           AS createdDate,
                  updated_date           AS updatedDate
    </select>

    <!-- ─── ADDITIONAL PHONE ────────────────────────────────────────────────── -->

    <insert id="addAdditionalPhoneNumber">
        INSERT INTO tb_distributor_phone VALUES (DEFAULT, #{infoId}, #{additionalPhoneNumber})
    </insert>

    <delete id="deleteAdditioanlPhoneNumber">
        DELETE FROM tb_distributor_phone WHERE distributor_info_id = #{infoId}
    </delete>

    <!-- ─── HELPERS ──────────────────────────────────────────────────────────── -->

    <select id="checkIfUserProfileIsCreated" resultType="boolean">
        SELECT EXISTS(SELECT * FROM tb_distributor_info WHERE distributor_account_id = #{currentUserId})
    </select>

    <select id="getDistributorInfoId" resultType="int">
        SELECT id FROM tb_distributor_info WHERE distributor_account_id = #{currentUserId}
    </select>

    <select id="checkIfAdditionalPhoneNumberExist" resultType="boolean">
        SELECT EXISTS(SELECT * FROM tb_distributor_phone WHERE phone_number = #{additionalPhoneNumber})
    </select>

    <select id="getDistributorIdByStoreId" resultType="int">
        SELECT distributor_account_id FROM tb_store WHERE id = #{storeId}
    </select>

</mapper>